set shell := ["bash", "-cu"]

component := source_directory()

default: test

dependencies:
    cd "{{component}}" && npm ci

install: dependencies

# The TextMate grammar is maintained as source and has no generated artifacts.
generate:
    @echo "VS Code TextMate sources are already generated"

test: dependencies
    cd "{{component}}" && npm test

package: dependencies
    cd "{{component}}" && npm run package

install-local: package
    cd "{{component}}" && code --install-extension --force "simi-language-$(node -p 'require(\"./package.json\").version').vsix"

# Marketplace publication is intentionally guarded and is never part of another recipe.
publish: test
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ "${CONFIRM_PUBLISH:-}" != "1" ]]; then
      echo "Refusing to publish. Re-run with CONFIRM_PUBLISH=1 and VSCE_PAT set." >&2
      exit 2
    fi
    : "${VSCE_PAT:?VSCE_PAT must contain a Visual Studio Marketplace token}"
    cd "{{component}}"
    npm run publish
