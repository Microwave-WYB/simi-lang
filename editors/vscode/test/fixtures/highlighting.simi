-- Classify values and exercise Simi's editing grammar.
fn classify(value, limit) do
    let threshold = 1.5e+2
    let message = "line\nvalue"
    if value >= threshold and not false then
        "large"
    elseif value == nil or value < limit then
        value ?> tap inspect()
    else
        case [value, message]
        of [head, ..tail] when true do
            { result = head, rest = tail }
        of _ do "small"
        end
    end
end

fn declared_effect(
    xs: [..integer] => [..(integer | string)],
    pair: [integer, string] => [..(integer | string)],
) -> nil do nil end

let mapper = fn(item) do item * 2 end
let iter = require("std/iter")
let mapped = iter.map(require("std/list").iter([1, 2])) <| mapper
let handled = try
    let attempted = { error = "bad" }
    raise attempted
catch { error = reason } do reason
end
let optional = do mapped? end
loop state = 0 do
    if state > 1 then break state else continue state + 1 end
end
let bad_escape = "\q"
let concatenated = "Simi" <> " language"
let integer_check = type(threshold) == "integer"
let function_check = type(mapper) == "function"
let is = integer_check
let piped = mapped |> list.length()
fn identity<'a: | integer | string>(value: 'a) -> 'a noraise do value end
let typed_mapper: <'a: any> (input: | integer | string) -> 'a raises string = nil
let generic_lambda = fn<'a: any>(value: 'a) -> 'a raises string do value end
let raises = 1
let noraise = raises
fn nested<'a: wrapper<integer>>(value: 'a) -> 'a noraise do value end
let typed_no_raise: () -> nil noraise = nil
let literal_raise: () -> nil raises "oops" = nil
