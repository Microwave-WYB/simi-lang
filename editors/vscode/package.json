{
  "name": "simi-language",
  "displayName": "Simi Language Support",
  "description": "Syntax highlighting and language-server support for the Simi scripting language.",
  "version": "0.1.0",
  "publisher": "simi",
  "license": "UNLICENSED",
  "main": "./src/extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "simi",
    "language",
    "syntax-highlighting",
    "language-server"
  ],
  "activationEvents": [
    "onLanguage:simi"
  ],
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "languages": [
      {
        "id": "simi",
        "aliases": [
          "Simi",
          "simi"
        ],
        "extensions": [
          ".simi"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "simi",
        "scopeName": "source.simi",
        "path": "./syntaxes/simi.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Simi",
      "properties": {
        "simi.languageServer.path": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Path to the simi-lsp executable. When empty, SIMI_LSP_PATH and then simi-lsp on PATH are used."
        }
      }
    },
    "commands": [
      {
        "command": "simi.restartLanguageServer",
        "title": "Simi: Restart Language Server"
      }
    ]
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "prepackage": "npm test",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "3.9.2",
    "vscode-oniguruma": "2.0.1",
    "vscode-textmate": "9.3.2"
  }
}
