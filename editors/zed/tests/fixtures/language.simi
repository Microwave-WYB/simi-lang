-- Exercises the syntax used by the Zed queries.
alias option('a) = 'a | nil
alias pair('a, 'b) = ['a, 'b]

let typed_value: option(string) = nil
let typed_record: { name: string, .. } = { name = "Simi" }

fn typed_identity(value: 'a) -> 'a do
    value
end

fn declared_effect(xs: [..integer], pair: [integer, string]) -> nil
    after xs becomes [..integer | string]
    after pair becomes [..integer | string]
do nil end

let list = require("std/list")

fn classify(value) do
    case value
    of [first, ..rest] when first >= 1 do
        { kind = "positive\n", value = first, rest = rest }
    of { error = message, ..details } do
        { kind = "error", message = message, details = details }
    of _ do nil
    end
end

let transform = fn(value) do
    if value == 0 then
        false
    elseif value != 1 and not false then
        true
    else
        value * 2 + 1 // 2 % 3
    end
end

let values = [1, 2.5e1, 3]
let result = values ?> list.map() <| transform
let optional = do result? end
let concatenated = "Simi" <> " language"
let has_runtime_label = type(result) == "list"
let is = has_runtime_label
let final = loop state = 0 do
    if state < 2 or state <= -1 then
        continue state + 1
    else
        break state
    end
end

try
    let error = { error = "example" }
    raise error
catch { error = message } when message != nil do
    classify([final])
catch _ do nil
end
