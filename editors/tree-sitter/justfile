set shell := ["sh", "-eu", "-c"]

component := source_directory()

# Install the pinned local Tree-sitter CLI.
install:
    cd "{{component}}" && npm ci

# Regenerate src/parser.c, src/grammar.json, and src/node-types.json.
generate:
    cd "{{component}}" && npm exec -- tree-sitter generate

# Regenerate and run all corpus tests.
test:
    cd "{{component}}" && npm test

# Create a local npm package without publishing it.
package: test
    mkdir -p "{{component}}/.artifacts"
    cd "{{component}}" && npm pack --pack-destination .artifacts
